# Copy this file to .env and fill in your own values.

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
# Used for BOTH competitor refreshes and negative-data classification in this
# project (no free-data-source split like the Cytokinetics project, since
# these competitors are private companies with no SEC-style filings).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

CLAUDE_MODEL=claude-sonnet-5

PORT=4001

# Origin allowed to call this API (your dashboard's URL). "*" = allow any
# origin -- fine for local testing, tighten once you have a real deployed
# frontend URL (see DEPLOYMENT notes from the Cytokinetics project -- same
# CORS rules apply here).
CORS_ORIGIN=*

# Optional: require this code on refresh/scan/approve/reject actions once
# this is hosted publicly, so random visitors can't spend your API credits.
DASHBOARD_ACCESS_CODE=

# Optional: if set, approving a negative-data finding will POST its JSON to
# this URL -- a real webhook call, in case you (or Elnora) want to point it
# at an actual ingestion endpoint later. Leave blank to just export manually.
ELNORA_WEBHOOK_URL=

# Europe PMC search terms -- edit these to tune what counts as "relevant" to
# Elnora's focus. Comma-separated; combined with negative-result language
# automatically by negativeDataAgent.js.
FOCUS_TERMS=antiviral,host-targeting,host cell,broad-spectrum antiviral
